{
  "name": "sand-together-shell",
  "private": true,
  "version": "0.1.0",
  "description": "Tauri shell for Sand Together — loads the bottle UI served by the VPS. The web UI itself stays vanilla JS with no build step (index.html).",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --features debugtools",
    "server": "node server/index.js",
    "migrate": "node server/migrate.mjs",
    "test:determinism": "node server/determinism.test.mjs",
    "test:replay": "node server/replay.test.mjs",
    "test:predict": "node server/predict.test.mjs",
    "test:lockstep": "node server/lockstep.test.mjs",
    "test:heal": "node server/heal.test.mjs",
    "test:route": "node server/patch-route.test.mjs",
    "test:bands": "node server/smoke-bands.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "wrangler": "^4.101.0"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
